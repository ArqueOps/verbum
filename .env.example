# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ukfwizdbtudkmgfaljtp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# App URL (used for redirects, webhooks, and absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Caramelou — Payment platform product IDs
# Monthly subscription product ID from Caramelou dashboard
CARAMELOU_PRODUCT_ID_MONTHLY=
# Annual subscription product ID from Caramelou dashboard
CARAMELOU_PRODUCT_ID_ANNUAL=

# Vercel (set automatically by Vercel)
# VERCEL_URL=
# VERCEL_ENV=

# --- OAuth Providers (Supabase Auth) ---

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_SECRET=your-google-client-secret
SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=http://127.0.0.1:54321/auth/v1/callback

# Apple OAuth
APPLE_CLIENT_ID=your-apple-client-id
APPLE_SECRET=your-apple-client-secret
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key-contents
SUPABASE_AUTH_EXTERNAL_APPLE_REDIRECT_URI=http://127.0.0.1:54321/auth/v1/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret
SUPABASE_AUTH_EXTERNAL_GITHUB_REDIRECT_URI=http://127.0.0.1:54321/auth/v1/callback
